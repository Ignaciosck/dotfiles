{
	// Place your snippets for cpp here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"usingStd": {
		"prefix": "usingstd",
		"body": [
			"using namespace std;"
		],
		"description": "using namespace std"
	},
	"include": {
		"prefix": "i_",
		"body": [
			"#include <$1>"
		],
		"description": "Include snippet"
	},
	"iostreamInclude": {
		"prefix": "i_ios",
		"body": [
			"#include <iostream>"
		],
		"description": "iostream include snippet"
	},
	"Function": {
		"prefix": "func",
		"body": [
			"${1:type} ${2:functionName}($3)",
			"{",
			"    return $4;",
			"}"
		],
		"description": "Function snippet."
	},
	"calculateProperty": {
		"prefix": "cvar",
		"body": [
			"${1:varType} ${2:varName} = ${3:funcName}($4);"
		],
		"description": "Calculate a variable calling a function."
	},
	"mainMethod": {
		"prefix": "main",
		"body": [
			"int main(int argc, char const *argv[])",
			"{",
			"    return EXIT_SUCCESS;",
			"}"
		],
		"description": "mainMethod"
	},
	"for": {
		"prefix": "for",
		"body": [
			"for (${1:size_t} ${2:i} = ${3:0}; ${2:i} ${4:< count}; ${2:i}++)",
			"{",
			"    $5;",
			"}"
		],
		"description": "for"
	},
	"foreach": {
		"prefix": "foreach",
		"body": [
			"for (auto ${1:varX} : ${2:varY})",
			"{",
			"    $3;",
			"}"
		],
		"description": "foreach loop"
	},
	"for_reversed": {
		"prefix": "for_r",
		"body": [
			"for (${1:int} ${2:i} = ${3:length}; ${2:i} ${4:< count}; ${2:i}--)",
			"{",
			"    $5;",
			"}"
		],
		"description": "for_reversed"
	},
	"varDeclaration": {
		"prefix": "var",
		"body": [
			"${1:varType} ${2:varName} = $3;"
		],
		"description": "Default var declaration"
	},
	"varDeclarationStruct": {
		"prefix": "varstruct",
		"body": [
			"${1:varType} ${2:varName};"
		],
		"description": "Default var declaration inside struct."
	},
	"while": {
		"prefix": "while",
		"body": [
			"while (${1:/* condition */})",
			"{",
			"    ${2:/* code */}",
			"}"
		],
		"description": "Snippet for a while loop."
	},
	"dowhile": {
		"prefix": "do",
		"body": [
			"",
			"do",
			"{",
			"    ${2:/* code */}",
			"}",
			"while (${1:/* condition */});",
			""
		],
		"description": "while"
	},
	"struct": {
		"prefix": "struct",
		"body": [
			"struct ${1:StructName}",
			"{",
			"    $2",
			"};"
		],
		"description": "Code snippet for struct"
	},
	"cout": {
		"prefix": "cout",
		"body": [
			"cout << ${1:/* message */} << endl;"
		],
		"description": "Code snippet a simple cout."
	},
	"if": {
		"prefix": "if",
		"body": [
			"if (${1:/* condition */)}",
			"{",
			"    ${2:/* code */}",
			"}"
		],
		"description": "Code snippet for an if statement."
	},
	"else": {
		"prefix": "else",
		"body": [
			"else",
			"{",
			"    ${1:/* code */}",
			"}"
		],
		"description": "Code snippet for an else statement."
	},
	"else_if": {
		"prefix": "elif",
		"body": [
			"else if (${1:/* condition */)}",
			"{",
			"    ${2:/* code */}",
			"}"
		],
		"description": "Code snippet for an else if statement."
	},
	"debug_hello": {
		"prefix": "hello",
		"body": [
			"cout << \" Hello \" << endl;",
			
		],
		"description": "Print hello"
	},
}